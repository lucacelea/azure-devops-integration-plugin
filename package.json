{
  "name": "azure-devops-integration",
  "displayName": "Azure DevOps Integration",
  "description": "A VS Code extension for Azure DevOps. Browse pull requests in a sidebar grouped by Created by me, Assigned to me, and My teams, review changes and discussions, get actionable comment notifications, and create PRs with linked work items.",
  "version": "0.7.0",
  "publisher": "lucacelea",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucacelea/azure-devops-integration-plugin"
  },
  "homepage": "https://github.com/lucacelea/azure-devops-integration-plugin#readme",
  "bugs": {
    "url": "https://github.com/lucacelea/azure-devops-integration-plugin/issues"
  },
  "keywords": [
    "azure devops",
    "pull request",
    "work item",
    "devops",
    "git"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "azureDevops.createPullRequest",
        "title": "Azure DevOps: Create Pull Request"
      },
      {
        "command": "azureDevops.openRepository",
        "title": "Azure DevOps: Open Repository"
      },
      {
        "command": "azureDevops.openWorkItem",
        "title": "Azure DevOps: Open Work Item"
      },
      {
        "command": "azureDevops.setToken",
        "title": "Azure DevOps: Set Personal Access Token"
      },
      {
        "command": "azureDevops.removeToken",
        "title": "Azure DevOps: Remove Personal Access Token"
      },
      {
        "command": "azureDevops.refreshPullRequests",
        "title": "Azure DevOps: Refresh Pull Requests",
        "icon": "$(refresh)"
      },
      {
        "command": "azureDevops.approvePr",
        "title": "Approve",
        "icon": "$(check)"
      },
      {
        "command": "azureDevops.approveWithSuggestionsPr",
        "title": "Approve with Suggestions",
        "icon": "$(check)"
      },
      {
        "command": "azureDevops.waitForAuthorPr",
        "title": "Wait for Author",
        "icon": "$(watch)"
      },
      {
        "command": "azureDevops.rejectPr",
        "title": "Reject",
        "icon": "$(close)"
      },
      {
        "command": "azureDevops.resetVotePr",
        "title": "Reset Vote",
        "icon": "$(circle-slash)"
      },
      {
        "command": "azureDevops.completePr",
        "title": "Complete",
        "icon": "$(merge)"
      },
      {
        "command": "azureDevops.abandonPr",
        "title": "Abandon",
        "icon": "$(trash)"
      },
      {
        "command": "azureDevops.addCommentPr",
        "title": "Add Comment",
        "icon": "$(comment)"
      },
      {
        "command": "azureDevops.editPrDescription",
        "title": "Edit Description",
        "icon": "$(edit)"
      },
      {
        "command": "azureDevops.editPrDescriptionFromPicker",
        "title": "Azure DevOps: Edit Pull Request Description"
      },
      {
        "command": "azureDevops.checkoutPrBranch",
        "title": "Checkout Branch",
        "icon": "$(source-control)"
      },
      {
        "command": "azureDevops.openPrInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "azureDevops.reviewPrChanges",
        "title": "Review Changes",
        "icon": "$(diff)"
      },
      {
        "command": "azureDevops.clearPrChanges",
        "title": "Clear PR Changes",
        "icon": "$(clear-all)"
      },
      {
        "command": "azureDevops.openPrFileDiff",
        "title": "Open Diff"
      },
      {
        "command": "azureDevops.filterPullRequests",
        "title": "Azure DevOps: Filter Pull Requests",
        "icon": "$(filter)"
      },
      {
        "command": "azureDevops.sortPullRequests",
        "title": "Azure DevOps: Sort Pull Requests",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "azureDevops.replyToComment",
        "title": "Submit Comment",
        "icon": "$(check)"
      },
      {
        "command": "azureDevops.openDiscussionComment",
        "title": "Open Comment"
      },
      {
        "command": "azureDevops.refreshPrDiscussion",
        "title": "Refresh Discussion",
        "icon": "$(refresh)"
      },
      {
        "command": "azureDevops.clearPrDiscussion",
        "title": "Clear Discussion",
        "icon": "$(clear-all)"
      },
      {
        "command": "azureDevops.replyToDiscussionThread",
        "title": "Reply",
        "icon": "$(comment)"
      },
      {
        "command": "azureDevops.addGeneralComment",
        "title": "Add Comment",
        "icon": "$(add)"
      },
      {
        "command": "azureDevops.editorApprovePr",
        "title": "Azure DevOps: Approve PR",
        "icon": "$(check)"
      },
      {
        "command": "azureDevops.editorRejectPr",
        "title": "Azure DevOps: Reject PR",
        "icon": "$(close)"
      },
      {
        "command": "azureDevops.editorWaitForAuthorPr",
        "title": "Azure DevOps: Wait for Author",
        "icon": "$(eye)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "azureDevops",
          "title": "Azure DevOps",
          "icon": "$(git-pull-request)"
        }
      ]
    },
    "views": {
      "azureDevops": [
        {
          "id": "azureDevops.pullRequests",
          "name": "Pull Requests"
        },
        {
          "id": "azureDevops.prChanges",
          "name": "PR Changes",
          "visibility": "collapsed"
        },
        {
          "id": "azureDevops.prDiscussion",
          "name": "PR Discussion",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "comments/commentThread/context": [
        {
          "command": "azureDevops.replyToComment",
          "group": "inline",
          "when": "commentController == azureDevopsPrComments"
        }
      ],
      "commandPalette": [
        {
          "command": "azureDevops.editPrDescription",
          "when": "false"
        },
        {
          "command": "azureDevops.editorApprovePr",
          "when": "false"
        },
        {
          "command": "azureDevops.editorRejectPr",
          "when": "false"
        },
        {
          "command": "azureDevops.editorWaitForAuthorPr",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "azureDevops.editorApprovePr",
          "when": "azureDevops.prDiffActive",
          "group": "navigation@1"
        },
        {
          "command": "azureDevops.editorWaitForAuthorPr",
          "when": "azureDevops.prDiffActive",
          "group": "navigation@2"
        },
        {
          "command": "azureDevops.editorRejectPr",
          "when": "azureDevops.prDiffActive",
          "group": "navigation@3"
        }
      ],
      "view/title": [
        {
          "command": "azureDevops.refreshPullRequests",
          "when": "view == azureDevops.pullRequests",
          "group": "navigation"
        },
        {
          "command": "azureDevops.filterPullRequests",
          "when": "view == azureDevops.pullRequests",
          "group": "navigation"
        },
        {
          "command": "azureDevops.sortPullRequests",
          "when": "view == azureDevops.pullRequests",
          "group": "navigation"
        },
        {
          "command": "azureDevops.clearPrChanges",
          "when": "view == azureDevops.prChanges",
          "group": "navigation"
        },
        {
          "command": "azureDevops.refreshPrDiscussion",
          "when": "view == azureDevops.prDiscussion",
          "group": "navigation"
        },
        {
          "command": "azureDevops.clearPrDiscussion",
          "when": "view == azureDevops.prDiscussion",
          "group": "navigation"
        },
        {
          "command": "azureDevops.addGeneralComment",
          "when": "view == azureDevops.prDiscussion",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "azureDevops.openPrInBrowser",
          "when": "viewItem == pullRequest",
          "group": "0_open@1"
        },
        {
          "command": "azureDevops.approvePr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@1"
        },
        {
          "command": "azureDevops.approveWithSuggestionsPr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@2"
        },
        {
          "command": "azureDevops.waitForAuthorPr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@3"
        },
        {
          "command": "azureDevops.rejectPr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@4"
        },
        {
          "command": "azureDevops.resetVotePr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@5"
        },
        {
          "command": "azureDevops.completePr",
          "when": "viewItem == pullRequest",
          "group": "2_actions@1"
        },
        {
          "command": "azureDevops.abandonPr",
          "when": "viewItem == pullRequest",
          "group": "2_actions@2"
        },
        {
          "command": "azureDevops.addCommentPr",
          "when": "viewItem == pullRequest",
          "group": "2_actions@3"
        },
        {
          "command": "azureDevops.editPrDescription",
          "when": "viewItem == pullRequest",
          "group": "2_actions@4"
        },
        {
          "command": "azureDevops.checkoutPrBranch",
          "when": "viewItem == pullRequest",
          "group": "3_branch@1"
        },
        {
          "command": "azureDevops.replyToDiscussionThread",
          "when": "viewItem == discussionThread",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Azure DevOps",
      "properties": {
        "azureDevops.organization": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization name. Auto-detected from git remote if not set."
        },
        "azureDevops.project": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project name. Auto-detected from git remote if not set."
        },
        "azureDevops.repository": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps repository name. Auto-detected from git remote if not set."
        },
        "azureDevops.workItemProject": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project for work items, if different from the repository's project. Falls back to azureDevops.project or the git remote's project."
        },
        "azureDevops.branchPrefix": {
          "type": "string",
          "default": "",
          "description": "Personal branch prefix to strip when parsing branch names (e.g., 'lucac/')."
        },
        "azureDevops.workItemPattern": {
          "type": "string",
          "default": "",
          "description": "Custom regex pattern to extract work item ID from branch name. Must contain a capture group for the ID. Leave empty to use default patterns."
        },
        "azureDevops.pullRequestLinkedWorkItemState": {
          "type": "string",
          "default": "",
          "description": "Optional state to set on the work item linked during pull request creation (for example: 'To verify'). Leave empty to keep the current state."
        },
        "azureDevops.pullRequestRefreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "description": "Interval in seconds to auto-refresh the pull request list (minimum 30)."
        },
        "azureDevops.pullRequestAutoComplete": {
          "type": "boolean",
          "default": false,
          "description": "Automatically set auto-complete on newly created pull requests."
        },
        "azureDevops.pullRequestMergeStrategy": {
          "type": "string",
          "default": "squash",
          "enum": [
            "noFastForward",
            "squash",
            "rebase",
            "rebaseMerge"
          ],
          "enumDescriptions": [
            "Merge (no fast-forward)",
            "Squash commit",
            "Rebase and fast-forward",
            "Semi-linear merge"
          ],
          "description": "Merge strategy to use when auto-completing a pull request."
        },
        "azureDevops.pullRequestDeleteSourceBranch": {
          "type": "boolean",
          "default": true,
          "description": "Delete source branch after merging when auto-complete is set."
        },
        "azureDevops.pullRequestCompleteWorkItems": {
          "type": "boolean",
          "default": true,
          "description": "Complete associated work items after merging when auto-complete is set."
        },
        "azureDevops.showAssignedWorkItems": {
          "type": "boolean",
          "default": true,
          "description": "Show a work item picker during pull request creation, allowing you to select work items assigned to you to link to the PR. Items from the branch name are pre-selected."
        },
        "azureDevops.pullRequestAutoOpenInBrowser": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the pull request in the browser after creation."
        },
        "azureDevops.richCopyUrl": {
          "type": "boolean",
          "default": false,
          "description": "Copy rich link with PR title to clipboard when copying pull request URL."
        },
        "azureDevops.notificationScope": {
          "type": "string",
          "enum": ["all", "participating", "off"],
          "enumDescriptions": [
            "Show notifications for all visible pull requests",
            "Show notifications only for pull requests you created or are assigned to",
            "Disable all notifications"
          ],
          "default": "all",
          "description": "Controls which pull requests trigger comment notifications."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  }
}
