{
  "name": "azure-devops-integration",
  "displayName": "Azure DevOps Integration",
  "description": "A VS Code extension for Azure DevOps. Browse pull requests in a sidebar grouped by Created by me, Assigned to me, and My teams, with review, check, and comment status. Auto-detects config from git remotes and extracts work item IDs from branch names. Create PRs, open repos, and link work items.",
  "version": "0.2.0",
  "publisher": "lucacelea",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucacelea/azure-devops-integration-plugin"
  },
  "homepage": "https://github.com/lucacelea/azure-devops-integration-plugin#readme",
  "bugs": {
    "url": "https://github.com/lucacelea/azure-devops-integration-plugin/issues"
  },
  "keywords": [
    "azure devops",
    "pull request",
    "work item",
    "devops",
    "git"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "azureDevops.createPullRequest",
        "title": "Azure DevOps: Create Pull Request"
      },
      {
        "command": "azureDevops.openRepository",
        "title": "Azure DevOps: Open Repository"
      },
      {
        "command": "azureDevops.openWorkItem",
        "title": "Azure DevOps: Open Work Item"
      },
      {
        "command": "azureDevops.setToken",
        "title": "Azure DevOps: Set Personal Access Token"
      },
      {
        "command": "azureDevops.removeToken",
        "title": "Azure DevOps: Remove Personal Access Token"
      },
      {
        "command": "azureDevops.refreshPullRequests",
        "title": "Azure DevOps: Refresh Pull Requests",
        "icon": "$(refresh)"
      },
      {
        "command": "azureDevops.approvePr",
        "title": "Approve",
        "icon": "$(check)"
      },
      {
        "command": "azureDevops.approveWithSuggestionsPr",
        "title": "Approve with Suggestions",
        "icon": "$(check)"
      },
      {
        "command": "azureDevops.waitForAuthorPr",
        "title": "Wait for Author",
        "icon": "$(watch)"
      },
      {
        "command": "azureDevops.rejectPr",
        "title": "Reject",
        "icon": "$(close)"
      },
      {
        "command": "azureDevops.resetVotePr",
        "title": "Reset Vote",
        "icon": "$(circle-slash)"
      },
      {
        "command": "azureDevops.completePr",
        "title": "Complete Pull Request",
        "icon": "$(merge)"
      },
      {
        "command": "azureDevops.abandonPr",
        "title": "Abandon Pull Request",
        "icon": "$(trash)"
      },
      {
        "command": "azureDevops.addCommentPr",
        "title": "Add Comment",
        "icon": "$(comment)"
      },
      {
        "command": "azureDevops.checkoutPrBranch",
        "title": "Checkout Branch",
        "icon": "$(source-control)"
      },
      {
        "command": "azureDevops.openPrInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "azureDevops.reviewPrChanges",
        "title": "Review Changes",
        "icon": "$(diff)"
      },
      {
        "command": "azureDevops.clearPrChanges",
        "title": "Clear PR Changes",
        "icon": "$(clear-all)"
      },
      {
        "command": "azureDevops.openPrFileDiff",
        "title": "Open Diff"
      },
      {
        "command": "azureDevops.addDiffComment",
        "title": "Azure DevOps: Add Comment on Line",
        "icon": "$(comment)"
      },
      {
        "command": "azureDevops.filterPullRequests",
        "title": "Azure DevOps: Filter Pull Requests",
        "icon": "$(filter)"
      },
      {
        "command": "azureDevops.sortPullRequests",
        "title": "Azure DevOps: Sort Pull Requests",
        "icon": "$(arrow-swap)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "azureDevops",
          "title": "Azure DevOps",
          "icon": "$(git-pull-request)"
        }
      ]
    },
    "views": {
      "azureDevops": [
        {
          "id": "azureDevops.pullRequests",
          "name": "Pull Requests"
        },
        {
          "id": "azureDevops.prChanges",
          "name": "PR Changes",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "azureDevops.addDiffComment",
          "when": "resourceScheme == azuredevops-pr && resourceQuery =~ /prId=/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "azureDevops.addDiffComment",
          "when": "resourceScheme == azuredevops-pr && resourceQuery =~ /prId=/",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "azureDevops.refreshPullRequests",
          "when": "view == azureDevops.pullRequests",
          "group": "navigation"
        },
        {
          "command": "azureDevops.filterPullRequests",
          "when": "view == azureDevops.pullRequests",
          "group": "navigation"
        },
        {
          "command": "azureDevops.sortPullRequests",
          "when": "view == azureDevops.pullRequests",
          "group": "navigation"
        },
        {
          "command": "azureDevops.clearPrChanges",
          "when": "view == azureDevops.prChanges",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "azureDevops.reviewPrChanges",
          "when": "viewItem == pullRequest",
          "group": "0_review@1"
        },
        {
          "command": "azureDevops.approvePr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@1"
        },
        {
          "command": "azureDevops.approveWithSuggestionsPr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@2"
        },
        {
          "command": "azureDevops.waitForAuthorPr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@3"
        },
        {
          "command": "azureDevops.rejectPr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@4"
        },
        {
          "command": "azureDevops.resetVotePr",
          "when": "viewItem == pullRequest",
          "group": "1_vote@5"
        },
        {
          "command": "azureDevops.completePr",
          "when": "viewItem == pullRequest",
          "group": "2_actions@1"
        },
        {
          "command": "azureDevops.abandonPr",
          "when": "viewItem == pullRequest",
          "group": "2_actions@2"
        },
        {
          "command": "azureDevops.addCommentPr",
          "when": "viewItem == pullRequest",
          "group": "2_actions@3"
        },
        {
          "command": "azureDevops.checkoutPrBranch",
          "when": "viewItem == pullRequest",
          "group": "3_branch@1"
        },
        {
          "command": "azureDevops.openPrInBrowser",
          "when": "viewItem == pullRequest",
          "group": "4_open@1"
        }
      ]
    },
    "configuration": {
      "title": "Azure DevOps",
      "properties": {
        "azureDevops.organization": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization name. Auto-detected from git remote if not set."
        },
        "azureDevops.project": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project name. Auto-detected from git remote if not set."
        },
        "azureDevops.repository": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps repository name. Auto-detected from git remote if not set."
        },
        "azureDevops.workItemProject": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project for work items, if different from the repository's project. Falls back to azureDevops.project or the git remote's project."
        },
        "azureDevops.branchPrefix": {
          "type": "string",
          "default": "",
          "description": "Personal branch prefix to strip when parsing branch names (e.g., 'lucac/')."
        },
        "azureDevops.workItemPattern": {
          "type": "string",
          "default": "",
          "description": "Custom regex pattern to extract work item ID from branch name. Must contain a capture group for the ID. Leave empty to use default patterns."
        },
        "azureDevops.pullRequestRefreshInterval": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "description": "Interval in seconds to auto-refresh the pull request list (minimum 30)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  }
}
